    {
      "name": "Vendor Verification",
      "description": "Company and Brand verification & status management endpoints. Only super_admin and vendor_admin can access these. Two independent systems: verification_status (pending/verified/rejected) and active/inactive status.",
      "item": [
        {
          "name": "Update Company Verification Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verification_status\": \"verified\",\n  \"risk_notes\": \"All documents verified and approved\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/companies/{{company_id}}/verification",
              "host": ["{{base_url}}"],
              "path": ["companies", "{{company_id}}", "verification"]
            },
            "description": "Update a company's verification status (pending/verified/rejected). Only super_admin and vendor_admin can access this. Payload: { verification_status: 'pending' | 'verified' | 'rejected', risk_notes: 'reason' }"
          },
          "response": []
        },
        {
          "name": "Update Company Status (Active/Inactive)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_status\": \"active\",\n  \"risk_notes\": \"Company reactivated\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/companies/{{company_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["companies", "{{company_id}}", "status"]
            },
            "description": "Update the active/inactive status of a company. Only super_admin and vendor_admin can access this. Payload: { company_status: 'active' | 'inactive', risk_notes: 'reason' }"
          },
          "response": []
        },
        {
          "name": "Bulk Update Company Verification",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_ids\": [\"{{company_id}}\"],\n  \"verification_status\": \"verified\",\n  \"risk_notes\": \"Bulk approved - all documents verified\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/companies/bulk-verification",
              "host": ["{{base_url}}"],
              "path": ["companies", "bulk-verification"]
            },
            "description": "Bulk update company verification status. Only super_admin and vendor_admin can access this. Payload: { company_ids: [...], verification_status: 'pending' | 'verified' | 'rejected', risk_notes: 'reason' }"
          },
          "response": []
        },
        {
          "name": "Update Brand Verification Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verification_status\": \"verified\",\n  \"risk_notes\": \"All documents verified\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/brands/{{brand_id}}/verification",
              "host": ["{{base_url}}"],
              "path": ["brands", "{{brand_id}}", "verification"]
            },
            "description": "Update a brand's verification status (pending/verified/rejected). Only super_admin and vendor_admin can access this. Payload: { verification_status: 'pending' | 'verified' | 'rejected', risk_notes: 'reason' }"
          },
          "response": []
        },
        {
          "name": "Update Brand Status (Active/Inactive)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
